{
  "expo": {
    "name": "Plyz",
    "slug": "signtouch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plyz",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "newArchEnabled": true,
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*",
      "web/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.plyz.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Plyz a besoin d'accéder à votre caméra pour prendre des photos et les appels vidéo.",
        "NSPhotoLibraryUsageDescription": "Plyz a besoin d'accéder à votre galerie pour sauvegarder vos photos signées.",
        "NSPhotoLibraryAddUsageDescription": "Plyz a besoin d'accéder à votre galerie pour sauvegarder vos photos signées.",
        "NSMicrophoneUsageDescription": "Plyz a besoin d'accéder à votre microphone pour les appels vidéo en direct.",
        "UIBackgroundModes": [
          "voip"
        ]
      },
      "associatedDomains": [
        "applinks:plyz.app"
      ]
    },
    "android": {
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.plyz.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "plyz.app",
              "pathPrefix": "/join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Plyz a besoin d'accéder à votre caméra pour prendre des photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Plyz a besoin d'accéder à votre galerie pour sauvegarder vos photos signées.",
          "savePhotosPermission": "Plyz a besoin d'accéder à votre galerie pour sauvegarder vos photos signées.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-video",
      "expo-asset",
      [
        "@daily-co/config-plugin-rn-daily-js",
        {
          "enableCamera": true,
          "enableMicrophone": true,
          "enableScreenShare": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df16b7ad-c6a1-42a0-a0a3-2f1e10ac614b"
      }
    },
    "owner": "clickzou"
  }
}
